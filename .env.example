# ─── Required: Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Required: EVM RPC / Data ────────────────────────────
ALCHEMY_API_KEY=
# Used for: RPC, holder distribution, gas, ENS

# ─── Required: Wallet Intelligence ───────────────────────
ZERION_API_KEY=
# Used for: get_wallet_pnl, track_smart_money (transactions feed)
# Free tier: https://developers.zerion.io

# ─── Required: Market Data ───────────────────────────────
# Dexscreener needs no key (public API)
COINGECKO_API_KEY=
# Free tier (demo key) works for get_historical_ohlc

# ─── Optional: Security & Social ─────────────────────────
# GoPlus Security needs no key (public API, rate limited)
LUNARCRUSH_API_KEY=
# Free tier for get_token_social_stats (optional — can fall back to Dexscreener)

# ─── Required: 0xbrain RAG ───────────────────────────────
OXBRAIN_BASE_URL=https://0xbrain-production.up.railway.app

# ─── Optional: Social Scraping (Block 5) ────────────────
# Telegram (read-only, Telethon with user session)
# Get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Path to Telethon session file. MUST be outside repo / in secret volume.
TELEGRAM_SESSION_PATH=./data/telegram.session

# Twitter/X: empty for Nitter fallback, or set for X API v2 bearer
TWITTER_BEARER_TOKEN=

# ─── Phase 3.5 (Solana) — not yet used, here for forward-compat ───
HELIUS_API_KEY=

# ─── Runtime config ──────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOKENS_BUDGET=50000
AGENT_REQUEST_TIMEOUT_SECONDS=60

# ─── CORS (comma-separated) ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173